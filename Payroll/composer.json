{
    "name": "blb/payroll",
    "type": "blb-plugin",
    "description": "BLB Payroll engine — country-neutral. Listens to source-module events, classifies pay items and calculates statutory deductions through the installed country pack, posts payroll lines.",
    "license": "AGPL-3.0-only",
    "autoload": {
        "psr-4": {
            "App\\Modules\\People\\Payroll\\": ""
        }
    },
    "extra": {
        "blb": {
            "module": "people/payroll",
            "version": "0.1.0",
            "description": "Payroll engine — country-neutral. Listens to HR source events; classifies pay items and calculates statutory deductions via the installed country pack.",
            "requires-modules": {
                "core/company": "*",
                "core/employee": "*",
                "people/settings": "*"
            },
            "optional-modules": {
                "people/attendance": "*",
                "people/leave": "*",
                "people/claim": "*"
            },
            "publishes-events": [],
            "consumes-events": [
                "App\\Modules\\People\\Attendance\\Events\\AttendanceOvertimeApproved",
                "App\\Modules\\People\\Attendance\\Events\\AttendanceAllowanceMaterialized",
                "App\\Base\\Pdf\\Events\\PdfArtifactRendered"
            ]
        }
    }
}
